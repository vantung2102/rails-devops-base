title
  = content_for(:title) || 'Daisyui on Rails'
meta[name="viewport" content="width=device-width, initial-scale=1,  maximum-scale=2, user-scalable=1, shrink-to-fit=no"]
meta[name="description" content="DaisyUI on Rails, a Rails starter template is designed to kickstart your Rails with daisyui project swiftly."]
meta[name="keywords" content="DaisyUI, Rails, TailwindCSS, Template, Bootstrap, Jumpstart, Kickstart, Stater"]
= csrf_meta_tags
= csp_meta_tag
= yield :head
link[rel="icon" href="/icon.png" type="image/png"]
link[rel="icon" href="/icon.svg" type="image/svg+xml"]
link[rel="apple-touch-icon" href="/icon.png"]
= vite_client_tag
= vite_javascript_tag 'application', 'data-turbo-track': 'reload'
script
  | document.documentElement.setAttribute('data-theme', window.localStorage.getItem('theme'))
